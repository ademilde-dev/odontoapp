{
  "collections": {
    "patients": {
      "description": "Registered patients in the dental clinic",
      "schema": {
        "id": "string",
        "name": "string",
        "phone": "string",
        "email": "string",
        "birthDate": "string",
        "allergies": "string",
        "notes": "string",
        "createdAt": "timestamp"
      }
    },
    "appointments": {
      "description": "Dental appointments and schedules",
      "schema": {
        "id": "string",
        "patientId": "string",
        "patientName": "string",
        "date": "string",
        "time": "string",
        "procedure": "string",
        "notes": "string",
        "status": "string (scheduled | confirmed | completed | cancelled)",
        "createdAt": "timestamp"
      }
    },
    "odontograms": {
      "description": "Patient odontogram states mapping clinical status of teeth",
      "schema": {
        "patientId": "string",
        "teethState": "object (map of room/tooth numbers to conditions)",
        "updatedAt": "timestamp"
      }
    }
  }
}
